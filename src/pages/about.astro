---
import DefaultLayout from "../layouts/default.astro";
---

<DefaultLayout title="Naviget - About Us">
    <div class="py-6 px-4 mx-auto max-w-7xl lg:pt-16">
        <div
            class="bg-neutral-secondary-soft border border-default rounded-base p-8 md:p-12 grid lg:grid-cols-2 gap-8 items-center"
        >
            <div>
                <h1 class="text-4xl md:text-6xl text-heading mb-8">
                    Meet the Team behind Naviget
                </h1>
                <ul class="text-body text-2xl">
                    <li>
                        <a
                            class="hover:text-fg-brand"
                            href="https://www.linkedin.com/in/anmollsharma/"
                            target="_blank"
                            rel="external nofollow"
                        >
                            Anmol Sharma
                        </a>
                    </li>
                    <li>
                        <a
                            class="hover:text-fg-brand"
                            href="https://linktr.ee/numberbee"
                            target="_blank"
                            rel="external nofollow"
                        >
                            Yash Garg
                        </a>
                    </li>
                    <li>
                        <a
                            class="hover:text-fg-brand"
                            href="https://www.linkedin.com/in/58anand-kumar/"
                            target="_blank"
                            rel="external nofollow"
                        >
                            Anand Kumar
                        </a>
                    </li>
                    <li>
                        <a
                            class="hover:text-fg-brand"
                            href="https://www.linkedin.com/in/premhpopatia04/"
                            target="_blank"
                            rel="external nofollow"
                        >
                            Prem Popatia
                        </a>
                    </li>
                </ul>
            </div>
            <img
                class="rounded-base"
                src="/images/team.webp"
                alt="Team Naviget"
            />
        </div>
    </div>
</DefaultLayout>
